  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.footer-tagline {
  max-width: 420px;
  color: #cbd5e1;
  line-height: 1.7;
}

.footer-nav {
  display: grid;
  gap: var(--space-sm);
}

.footer-nav a,
.social-link {
  color: #e2e8f0;
  transition: color var(--transition-fast), transform var(--transition-fast), background-color var(--transition-fast);
}

.footer-nav a:hover {
  color: #67e8f9;
  transform: translateX(2px);
}

.footer-social {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-sm);
  justify-content: flex-end;
}

.social-link {
